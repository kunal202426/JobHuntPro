# ── Frontend (Vite) — environment template ─────────────────────────────────
# Copy to .env for local dev. In production these are set in the Vercel dashboard.
# All VITE_* vars are PUBLIC (bundled into the client) — never put secrets here.

# Backend URLs (your deployed Render services)
VITE_COLD_API_URL=https://your-cold-api.onrender.com
VITE_LINKEDIN_API_URL=https://your-linkedin-api.onrender.com

# Google OAuth Client ID (must match GOOGLE_CLIENT_ID in cold/backend).
# Reusing the existing project's client ID.
VITE_GOOGLE_CLIENT_ID=

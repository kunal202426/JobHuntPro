{
  "name": "jobhunt-pro",
  "version": "1.0.0",
  "private": true,
  "description": "Unified workspace: JobHunt Engine + Cold Outreach Hub",
  "scripts": {
    "start": "concurrently --names \"LinkedIn,Cold,Hub\" --prefix-colors \"green,blue,yellow\" --kill-others-on-fail \"npm:start:linkedin\" \"npm:start:cold\" \"npm:start:hub\"",
    "start:linkedin": "cd linkedin/backend && node server.js",
    "start:cold": "cd cold/backend && venv\\Scripts\\python -m uvicorn main:app --reload --port 8000",
    "start:hub": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "axios": "^1.16.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}

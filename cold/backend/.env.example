# ── Cold Email Backend — environment template ──────────────────────────────
# Copy to .env and fill in real values. NEVER commit the real .env.

# REQUIRED — app refuses to start without these
JWT_SECRET=                 # 64-char random string. MUST match the LinkedIn backend. openssl rand -hex 32
FIELD_ENCRYPTION_KEY=       # Fernet key. python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# DATABASE — Neon Postgres (free, non-local) in production. Local dev can use
# the default SQLite file. SQLAlchemy is DB-agnostic so the same ORM works on both.
#   Local:      sqlite:///./cold_email.db
#   Neon (prod): postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL=sqlite:///./cold_email.db

# CORS — comma-separated allowed origins (your Vercel frontend URL)
CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGIN_REGEX=^chrome-extension://.*$

# Google OAuth (Sign-In + Gmail send). Reuse existing project's credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI generation — server-side shared fallback pool (users can add their own keys)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
OPENROUTER_API_KEY=
# Optional: override the OpenRouter model fallback list (comma-separated)
# OPENROUTER_MODELS=

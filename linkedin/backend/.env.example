# ── LinkedIn Backend — environment template ────────────────────────────────
# Copy to .env and fill in real values. NEVER commit the real .env.

# REQUIRED — server throws on startup if missing. MUST be the SAME value as the
# cold backend's JWT_SECRET so tokens issued by either backend verify on both.
JWT_SECRET=

# DATABASE — Turso (free remote libsql). Leave blank for local file dev.
# Production (Turso):
#   LIBSQL_URL=libsql://<db-name>-<org>.turso.io
#   LIBSQL_AUTH_TOKEN=<turso auth token>
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
# Local dev only (ignored if LIBSQL_URL is set): path to the file DB
# SQLITE_DB_PATH=./data/jobhunt.db

# CORS — comma-separated extra allowed origins (your Vercel frontend URL).
# localhost and chrome-extension:// are always allowed.
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Server
PORT=3001
NODE_ENV=production

# Scoring thresholds (rule-based scorer — no AI keys needed anymore)
JOB_SCORE_THRESHOLD=6
LEAD_SCORE_THRESHOLD=7
DAILY_CONNECTION_LIMIT=50
